# ── Azure AI Foundry / OpenAI ─────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<foundry-project>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure AI Search ───────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<name>.search.windows.net
AZURE_SEARCH_API_KEY=<key>
AZURE_SEARCH_INDEX_NAME=client-knowledge

# ── Azure Cosmos DB ───────────────────────────────────────────────
# Master database name. Per-client databases are auto-created as client_{id}
COSMOS_ENDPOINT=https://<name>.documents.azure.com:443/
COSMOS_KEY=<key>
COSMOS_DB_NAME=clientagent

# ── Application Insights ──────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...
DISABLE_TELEMETRY=false

# ── OneDrive sync path ────────────────────────────────────────────
ONEDRIVE_SYNC_PATH=/mnt/onedrive

# ── Auth ──────────────────────────────────────────────────────────
ENTRA_CLIENT_ID=<app-registration-client-id>
ENTRA_TENANT_ID=<tenant-id>
LOCAL_MODE=false

# ── MCP Servers (external consumers) ─────────────────────────────
MCP_MS_LEARN_ENABLED=false
MCP_MS_LEARN_ENDPOINT=https://learn.microsoft.com/api/mcp
MCP_MS_GRAPH_ENABLED=false
MCP_MS_GRAPH_ENDPOINT=https://graph.microsoft.com/mcp

# ── MCP Server (this app as provider) ────────────────────────────
# Set in agent configs: http://localhost:8000/mcp/sse
MCP_LOG_DIR=./logs/mcp

# ── App ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=8000
LOG_LEVEL=INFO
